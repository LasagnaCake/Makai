import core.io

using core.io

module Test.Namespace {
	@Nullable
	struct MySpecialStruct {
		example : int = 0
	}

	foo :: (var: int) -> int {
		return var + var if ref var > 0 else foo(-var);
	}

	bar :: (var: int) -> int => (foo(var) * var)

	baz :: (var: int) => writeLine(bar(var) - var)

	biff :: () -> void
}

@Main
main :: () {
	writeLine("Hello, World!")
}
