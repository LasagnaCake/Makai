using import core

isEven :: (val: uint64) => if val % 2 IO.writeLine("Is odd!") else IO.writeLine("Is even!")

isEven2 :: (val: uint64) => IO.writeLine("Is odd!" if val % 2 else "Is even!")

@Main
main :: () {
	val: uint64 = 0
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
	isEven2((ref val)++)
}
