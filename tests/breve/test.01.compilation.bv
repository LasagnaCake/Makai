using import core;

module Test.Namespace {
	@Nullable
	struct MySpecialStruct {
		example : int64 = 0
	}

	foo :: (var: int64) -> int64 {
		return copy var + ref var
	}

	bar :: (var: int64) -> int64 => (foo(copy var) * ref var)

	baz :: (var: int64) => (bar(copy var) - ref var)

	biff :: () -> void
}

@Main
main :: () {
    val := Test.Namespace.baz(32 + 64)
    IO.write("32 + 64 = ")
    IO.writeLine(val as any)
}
