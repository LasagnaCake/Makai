using import core

module Test.Namespace {
	@Nullable
	struct MySpecialStruct {
		example : int64 = 0
	}

	foo :: (var: int64) -> int64 {
		return (copy var) + (ref var)
	}

	bar :: (var: int64) -> int64 => (foo(copy var) * ref var)

	baz :: (var: int64) => (bar(copy var) - ref var)

	biff :: () -> void
	
	printToOutput :: () => IO.writeLine("Beginning calculations...")
}

@Main
main :: () {
    IO.writeLine("We are calculating!")
    Test.Namespace.printToOutput()
    val := 32 + 64
    IO.write("32 + 64 = ")
    IO.writeLine(val as any)
    val = Test.Namespace.baz(32 + 64)
    IO.write("baz(32 + 64) = ")
    IO.writeLine(val as any)
    val = 32 - 64
    IO.write("32 - 64 = ")
    IO.writeLine(val as any)
    val = Test.Namespace.baz(32 - 64)
    IO.write("baz(32 - 64) = ")
    IO.writeLine(val as any)
}
